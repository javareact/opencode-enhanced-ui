{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-enhanced-ui",
  "displayName": "OpenCode Enhanced UI",
  "description": "VS Code enhanced UI for opencode",
  "private": true,
  "version": "1.0.1",
  "publisher": "LanTingxin",
  "icon": "images/logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LanTingxin/opencode-enhanced-ui.git"
  },
  "homepage": "https://github.com/LanTingxin/opencode-enhanced-ui#readme",
  "bugs": {
    "url": "https://github.com/LanTingxin/opencode-enhanced-ui/issues"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "opencode",
    "ai",
    "enhanced",
    "assistant",
    "sessions",
    "remote-ssh"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:opencode-ui.sessions",
    "onView:opencode-ui.sessionView",
    "onView:opencode-ui.subagents",
    "onCommand:opencode-ui.refresh",
    "onCommand:opencode-ui.newSession",
    "onCommand:opencode-ui.openSession",
    "onCommand:opencode-ui.renameSession",
    "onCommand:opencode-ui.archiveSession",
    "onCommand:opencode-ui.shareSession",
    "onCommand:opencode-ui.unshareSession",
    "onCommand:opencode-ui.openOutput",
    "onCommand:opencode-ui.openSettings",
    "onCommand:opencode-ui.checkEnvironment",
    "onCommand:opencode-ui.refreshWorkspaceSessions",
    "onCommand:opencode-ui.openWorkspaceInBrowser",
    "onCommand:opencode-ui.restartWorkspaceServer",
    "onCommand:opencode-ui.quickNewSession",
    "onCommand:opencode-ui.askSelection",
    "onCommand:opencode-ui.askCurrentFile",
    "onCommand:opencode-ui.askExplorerFiles",
    "onCommand:opencode-ui.searchWorkspaceSessions",
    "onCommand:opencode-ui.clearWorkspaceSessionSearch",
    "onCommand:opencode-ui.manageSessionTags",
    "onCommand:opencode-ui.filterWorkspaceSessionsByTag",
    "onCommand:opencode-ui.clearWorkspaceTagFilter",
    "onCommand:opencode-ui.copyImagePreview",
    "onCommand:opencode-ui.saveImagePreview",
    "onWebviewPanel:opencode-ui.session"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test ./src/panel ./src/test",
    "test:e2e": "bun run compile && wdio run ./wdio.conf.ts",
    "parity:composer": "bun test src/test/parity/composer-parity.test.ts",
    "parity:integration": "bun test src/test/parity/composer-integration.test.ts",
    "parity:upstream": "bun run src/test/parity/check-upstream-parity.ts",
    "parity:upstream:golden": "bun run src/test/parity/generate-upstream-golden.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.4.3",
    "diff": "^8.0.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.x",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "expect-webdriverio": "^5.6.5",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wdio-vscode-service": "^6.1.4",
    "webdriverio": "^9.27.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-ui",
          "title": "OpenCode",
          "icon": "images/activity.png"
        }
      ],
      "secondarySidebar": [
        {
          "id": "opencode-ui-secondary",
          "title": "OpenCode",
          "icon": "images/activity.png"
        }
      ]
    },
    "views": {
      "opencode-ui": [
        {
          "id": "opencode-ui.sessions",
          "name": "Sessions"
        },
        {
          "id": "opencode-ui.todo",
          "name": "Todo",
          "type": "webview"
        },
        {
          "id": "opencode-ui.diff",
          "name": "Modified Files",
          "type": "webview"
        },
        {
          "id": "opencode-ui.subagents",
          "name": "Subagents",
          "type": "webview"
        }
      ],
      "opencode-ui-secondary": [
        {
          "id": "opencode-ui.sessionView",
          "name": "Session",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-ui.refresh",
        "title": "OpenCode: Refresh",
        "shortTitle": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "opencode-ui.newSession",
        "title": "OpenCode: New Session",
        "shortTitle": "New",
        "icon": "$(add)"
      },
      {
        "command": "opencode-ui.openOutput",
        "title": "OpenCode: Open Output"
      },
      {
        "command": "opencode-ui.openSettings",
        "title": "OpenCode: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "opencode-ui.checkEnvironment",
        "title": "OpenCode: Check Environment",
        "icon": "$(debug-alt)"
      },
      {
        "command": "opencode-ui.copyImagePreview",
        "title": "Copy Image"
      },
      {
        "command": "opencode-ui.saveImagePreview",
        "title": "Save Image"
      },
      {
        "command": "opencode-ui.refreshWorkspaceSessions",
        "title": "OpenCode: Refresh Workspace Sessions",
        "shortTitle": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "opencode-ui.openWorkspaceInBrowser",
        "title": "OpenCode: Open Workspace In Browser",
        "shortTitle": "Open Web",
        "icon": "$(globe)"
      },
      {
        "command": "opencode-ui.openSession",
        "title": "OpenCode: Open Session",
        "icon": "$(arrow-right)"
      },
      {
        "command": "opencode-ui.renameSession",
        "title": "OpenCode: Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "opencode-ui.archiveSession",
        "title": "OpenCode: Archive Session",
        "icon": "$(archive)"
      },
      {
        "command": "opencode-ui.shareSession",
        "title": "OpenCode: Share Session",
        "icon": "$(link)"
      },
      {
        "command": "opencode-ui.unshareSession",
        "title": "OpenCode: Unshare Session",
        "icon": "$(unlock)"
      },
      {
        "command": "opencode-ui.restartWorkspaceServer",
        "title": "OpenCode: Restart Workspace Server",
        "shortTitle": "Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "opencode-ui.quickNewSession",
        "title": "OpenCode: Quick New Session",
        "shortTitle": "OpenCode",
        "icon": {
          "light": "images/button-dark.png",
          "dark": "images/button-light.png"
        }
      },
      {
        "command": "opencode-ui.askSelection",
        "title": "OpenCode: Ask About Selection"
      },
      {
        "command": "opencode-ui.askCurrentFile",
        "title": "OpenCode: Ask About Current File"
      },
      {
        "command": "opencode-ui.askExplorerFiles",
        "title": "OpenCode: Ask About Selected Files"
      },
      {
        "command": "opencode-ui.searchWorkspaceSessions",
        "title": "OpenCode: Search Sessions",
        "icon": "$(search)"
      },
      {
        "command": "opencode-ui.clearWorkspaceSessionSearch",
        "title": "OpenCode: Clear Session Search",
        "icon": "$(close)"
      },
      {
        "command": "opencode-ui.manageSessionTags",
        "title": "OpenCode: Manage Session Tags",
        "icon": "$(tag)"
      },
      {
        "command": "opencode-ui.filterWorkspaceSessionsByTag",
        "title": "OpenCode: Filter Sessions By Tag",
        "icon": "$(tag)"
      },
      {
        "command": "opencode-ui.clearWorkspaceTagFilter",
        "title": "OpenCode: Clear Session Tag Filter",
        "icon": "$(close)"
      }
    ],
    "configuration": {
      "title": "OpenCode Enhanced UI",
      "properties": {
        "opencode-ui.showThinking": {
          "type": "boolean",
          "default": true,
          "description": "Show thinking blocks in session panels.",
          "scope": "machine-overridable"
        },
        "opencode-ui.showInternals": {
          "type": "boolean",
          "default": false,
          "description": "Show internal transcript blocks in session panels.",
          "scope": "machine-overridable"
        },
        "opencode-ui.diffMode": {
          "type": "string",
          "default": "unified",
          "enum": [
            "unified",
            "split"
          ],
          "markdownEnumDescriptions": [
            "Render diffs in a unified view.",
            "Render diffs in a split view."
          ],
          "description": "Choose how diffs render in session panels.",
          "scope": "machine-overridable"
        },
        "opencode-ui.compactSkillInvocations": {
          "type": "boolean",
          "default": true,
          "description": "Render OpenCode skill usage as a compact skill marker in session panels.",
          "scope": "machine-overridable"
        },
        "opencode-ui.showSkillsInSlashAutocomplete": {
          "type": "boolean",
          "default": false,
          "description": "Show all skill commands directly in slash autocomplete. When enabled, the local /skills picker entry is hidden.",
          "scope": "machine-overridable"
        },
        "opencode-ui.panelTheme": {
          "type": "string",
          "default": "classic",
          "enum": [
            "classic",
            "codex",
            "claude"
          ],
          "markdownEnumDescriptions": [
            "Use the standard OpenCode panel styling and follow the active VS Code light or dark theme.",
            "Use a more tool-like panel preset with stronger framing while still following the active VS Code light or dark theme.",
            "Use a softer panel preset with gentler surfaces while still following the active VS Code light or dark theme."
          ],
          "description": "Choose the visual preset for session panels. Light or dark rendering still follows the active VS Code theme.",
          "scope": "machine-overridable"
        },
        "opencode-ui.panelColorScheme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "nocturne",
            "orchid",
            "verdant",
            "solar",
            "graphite",
            "ember"
          ],
          "markdownEnumDescriptions": [
            "Use the color palette designed for the selected panel preset.",
            "Use a night-focused blue, violet, cyan, and soft amber palette.",
            "Use a muted mauve, rose, sage, and apricot palette.",
            "Use a sage, teal, lake blue, and wheat palette for long reading sessions.",
            "Use a solarized cyan, blue, olive, and amber palette with low fatigue contrast.",
            "Use a neutral blue-gray, teal, brass, and copper palette.",
            "Use a restrained ember, olive, mint, and cyan palette."
          ],
          "description": "Choose the color palette for session panels. Light or dark rendering still follows the active VS Code theme.",
          "scope": "machine-overridable"
        },
        "opencode-ui.httpProxy": {
          "type": "string",
          "default": "",
          "description": "Optional HTTP_PROXY value used when launching opencode serve. Leave empty to inherit the existing environment, or fall back to VS Code http.proxy when no proxy env is present. Requires editor restart to take effect.",
          "scope": "machine-overridable"
        },
        "opencode-ui.opencodePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the opencode executable used to launch opencode serve. Leave empty to look up opencode on PATH. Useful when opencode is installed to a custom location. Requires editor restart to take effect.",
          "scope": "machine-overridable"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "opencode-ui.quickNewSession",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-ui.askSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "navigation@1"
        },
        {
          "command": "opencode-ui.askCurrentFile",
          "when": "editorTextFocus",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-ui.askExplorerFiles",
          "when": "!explorerResourceIsFolder",
          "group": "navigation@1"
        }
      ],
      "webview/context": [
        {
          "command": "opencode-ui.copyImagePreview",
          "when": "webviewId == 'opencode-ui.session' && webviewSection == 'imagePreview'",
          "group": "navigation@1"
        },
        {
          "command": "opencode-ui.saveImagePreview",
          "when": "webviewId == 'opencode-ui.session' && webviewSection == 'imagePreview'",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "opencode-ui.openSettings",
          "when": "view == opencode-ui.sessions",
          "group": "navigation@99"
        }
      ],
      "view/item/context": [
        {
          "command": "opencode-ui.newSession",
          "when": "view == opencode-ui.sessions && (viewItem == workspace || viewItem == workspace-searching || viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@1"
        },
        {
          "command": "opencode-ui.searchWorkspaceSessions",
          "when": "view == opencode-ui.sessions && (viewItem == workspace || viewItem == workspace-searching || viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@2"
        },
        {
          "command": "opencode-ui.refreshWorkspaceSessions",
          "when": "view == opencode-ui.sessions && (viewItem == workspace || viewItem == workspace-searching || viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@3"
        },
        {
          "command": "opencode-ui.openWorkspaceInBrowser",
          "when": "view == opencode-ui.sessions && (viewItem == workspace || viewItem == workspace-searching || viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@4"
        },
        {
          "command": "opencode-ui.filterWorkspaceSessionsByTag",
          "when": "view == opencode-ui.sessions && (viewItem == workspace || viewItem == workspace-searching || viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@2"
        },
        {
          "command": "opencode-ui.clearWorkspaceSessionSearch",
          "when": "view == opencode-ui.sessions && (viewItem == workspace-searching || viewItem == workspace-filtered)",
          "group": "inline@3"
        },
        {
          "command": "opencode-ui.clearWorkspaceTagFilter",
          "when": "view == opencode-ui.sessions && (viewItem == workspace-tag-filtered || viewItem == workspace-filtered)",
          "group": "inline@4"
        },
        {
          "command": "opencode-ui.renameSession",
          "when": "view == opencode-ui.sessions && (viewItem == session || viewItem == session-shared)",
          "group": "inline@1"
        },
        {
          "command": "opencode-ui.shareSession",
          "when": "view == opencode-ui.sessions && viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "opencode-ui.unshareSession",
          "when": "view == opencode-ui.sessions && viewItem == session-shared",
          "group": "inline@2"
        },
        {
          "command": "opencode-ui.archiveSession",
          "when": "view == opencode-ui.sessions && (viewItem == session || viewItem == session-shared)",
          "group": "inline@3"
        },
        {
          "command": "opencode-ui.manageSessionTags",
          "when": "view == opencode-ui.sessions && (viewItem == session || viewItem == session-shared)",
          "group": "inline@4"
        },
        {
          "command": "opencode-ui.clearWorkspaceSessionSearch",
          "when": "view == opencode-ui.sessions && viewItem == clear-search",
          "group": "inline@1"
        },
        {
          "command": "opencode-ui.clearWorkspaceTagFilter",
          "when": "view == opencode-ui.sessions && viewItem == clear-tag-filter",
          "group": "inline@1"
        }
      ]
    }
  },
  "packageManager": "bun@1.3.10"
}
